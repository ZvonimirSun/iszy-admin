# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Backend API origin, for Nuxt server API proxy and auth requests
NUXT_PUBLIC_API_ORIGIN=

# Redis-backed session storage
NUXT_REDIS_HOST=
NUXT_REDIS_PORT=6379
NUXT_REDIS_PASSWORD=

# Server-side session cookie
NUXT_SESSION_COOKIE_NAME=NUXT_SESSION_ID
NUXT_SESSION_MAX_AGE=7d
NUXT_SESSION_DOMAIN=
